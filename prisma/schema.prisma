generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  country      String    @default("US")
  isOnboarded  Boolean   @default(false)
  role         String    @default("user")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile       UserProfile?
  foodLogs      FoodLog[]
  weightLogs    WeightLog[]
  waterLogs     WaterLog[]
  mealSessions  MealSession[]
  savedFoods    SavedFood[]
  savedMeals    SavedMeal[]
  dailySummaries DailySummary[]
  aiSettings    AISettings?
  aiTokenUsage  AITokenUsage[]
  notifications Notification[]
}

model UserProfile {
  id                  String  @id @default(cuid())
  userId              String  @unique
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  age                 Int     @default(25)
  gender              String  @default("male")
  heightCm            Float   @default(170)
  weightKg            Float   @default(70)
  bodyFatPercent      Float?
  waistCm             Float?
  goal                String  @default("maintain")
  targetWeightKg      Float?
  targetWeeks         Int?
  activityLevel       String  @default("moderate")
  exerciseTypes       String  @default("[]")
  exerciseDaysPerWeek Int     @default(3)
  dietaryRestrictions String  @default("[]")
  medicalConditions   String  @default("[]")
  mealCount           Int     @default(3)
  cuisine             String  @default("general")
  dailyCalorieTarget  Int     @default(2000)
  dailyProteinTarget  Int     @default(150)
  dailyCarbTarget     Int     @default(200)
  dailyFatTarget      Int     @default(65)
  dailyWaterTargetMl  Int     @default(2500)
}

model MealSession {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  scheduledTime String    @default("08:00")
  orderIndex    Int       @default(0)
  foodLogs      FoodLog[]
}

model FoodLog {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealSessionId String?
  mealSession   MealSession? @relation(fields: [mealSessionId], references: [id])
  foodName      String
  brand         String?
  quantity      Float
  unit          String      @default("g")
  calories      Float
  protein       Float
  carbs         Float
  fat           Float
  fiber         Float?
  sugar         Float?
  sodium        Float?
  loggedAt      DateTime    @default(now())
  aiParsed      Boolean     @default(false)
}

model SavedFood {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodName    String
  brand       String?
  defaultQty  Float   @default(100)
  unit        String  @default("g")
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  timesUsed   Int     @default(1)
}

model SavedMeal {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  foods         String
  totalCalories Float
  totalProtein  Float
}

model WeightLog {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg Float
  loggedAt DateTime @default(now())
}

model WaterLog {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMl Int
  loggedAt DateTime @default(now())
}

model DailySummary {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            String
  totalCalories   Float    @default(0)
  totalProtein    Float    @default(0)
  totalCarbs      Float    @default(0)
  totalFat        Float    @default(0)
  totalWaterMl    Int      @default(0)
  calorieGoalHit  Boolean  @default(false)
  proteinGoalHit  Boolean  @default(false)
  waterGoalHit    Boolean  @default(false)
  aiSummaryText   String?
  aiProviderUsed  String?

  @@unique([userId, date])
}

model AISettings {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         String  @default("groq")
  model            String  @default("llama3-70b-8192")
  apiKeyEncrypted  String?
  baseUrl          String?
  fallbackProvider String  @default("gemini")
  fallbackModel    String  @default("gemini-1.5-flash")
}

model AITokenUsage {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String
  tokensUsed Int
  date       String
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
